{
  "name": "classroom-pet-manager",
  "version": "3.8.0",
  "description": "班级积分管理系统宠物版 - Windows 7/8 兼容版",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:win7": "electron-builder --win --ia32",
    "dist": "electron-builder --publish=never"
  },
  "keywords": [
    "classroom",
    "management",
    "pet",
    "education",
    "electron"
  ],
  "author": "班级积分管理系统",
  "license": "MIT",
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.classroom.pet.manager",
    "productName": "班级积分管理系统宠物版",
    "directories": {
      "output": "dist-win7"
    },
    "files": [
      "index.html",
      "electron-main.js",
      "float-ball.html",
      "pet/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "pet",
        "to": "pet"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["ia32", "x64"]
        },
        {
          "target": "nsis",
          "arch": ["ia32", "x64"]
        }
      ],
      "icon": "pet/仓鼠/1.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "班级积分管理系统宠物版"
    }
  }
}
